ALLOWED_ASSETS=USDC,XLM

PORT=3001

# Required for contract operations
# WARNING: Never commit real private keys to git! Use environment variables or secure vaults.
CONTRACT_ID=C1234567890ABCDEF1234567890ABCDEF1234567890ABCDEF1234567890
SERVER_PRIVATE_KEY=S1234567890ABCDEF1234567890ABCDEF1234567890ABCDEF1234567890

# Optional
RPC_URL=https://soroban-testnet.stellar.org:443
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
HORIZON_URL=https://horizon-testnet.stellar.org

# Redis cache (optional, for multi-instance deployments)
# If not set, uses in-memory cache
# Example: redis://localhost:6379 or redis://:password@host:port
# REDIS_URL=redis://localhost:6379

# Admin API key (minimum 32 characters in production)
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=your-admin-api-key-here-minimum-32-characters

# Webhook configuration
WEBHOOK_DESTINATION_URL=https://your-app.com/webhooks/stellar-stream
WEBHOOK_SIGNING_SECRET=your-webhook-signing-secret-here

# JWT configuration (required in production)
JWT_SECRET=your-jwt-secret-here

# Indexer configuration
INDEXER_POLL_INTERVAL_MS=10000

# Reconciliation job interval in milliseconds (minimum 10000, default 60000 = 1 minute)
RECONCILIATION_INTERVAL_MS=60000

# CORS allowed origins (comma-separated for multiple origins)
# In production, restrict to your frontend URL(s)
# Example: ALLOWED_ORIGINS=https://stream.app.example.com
# If unset, wildcard (*) is used for local development.
ALLOWED_ORIGINS=https://stream.app.example.com
